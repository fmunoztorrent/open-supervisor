{
  "id": "open-supervisor",
  "realm": "open-supervisor",
  "displayName": "Open Supervisor",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": true,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "directGrantFlow": "direct grant",
  "accessTokenLifespan": 28800,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 86400,
  "clients": [
    {
      "clientId": "bff",
      "name": "BFF Client",
      "enabled": true,
      "publicClient": false,
      "secret": "bff-secret-dev",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [],
      "webOrigins": [],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "28800",
        "client.session.idle.timeout": "28800",
        "client.session.max.lifespan": "86400"
      },
      "protocolMappers": [
        {
          "name": "storeId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "storeId",
            "claim.name": "storeId",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "displayName",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "displayName",
            "claim.name": "displayName",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "jobTitle",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "jobTitle",
            "claim.name": "jobTitle",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "department",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "department",
            "claim.name": "department",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "12345678-9",
      "enabled": true,
      "email": "juan.perez@opensupervisor.local",
      "firstName": "Juan",
      "lastName": "Pérez",
      "credentials": [
        {
          "type": "password",
          "value": "password1",
          "temporary": false
        }
      ],
      "attributes": {
        "storeId": ["store-1"],
        "displayName": ["Juan Pérez"],
        "jobTitle": ["Supervisor de Turno"],
        "department": ["Operaciones"]
      }
    },
    {
      "username": "99999999-0",
      "enabled": false,
      "email": "roberto.inactivo@opensupervisor.local",
      "firstName": "Roberto",
      "lastName": "Inactivo",
      "credentials": [
        {
          "type": "password",
          "value": "password0",
          "temporary": false
        }
      ],
      "attributes": {
        "storeId": ["store-1"]
      }
    }
  ],
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "id": "openldap-federation",
        "name": "openldap",
        "providerId": "ldap",
        "subComponents": {},
        "config": {
          "enabled": ["true"],
          "priority": ["0"],
          "fullSyncPeriod": ["-1"],
          "changedSyncPeriod": ["-1"],
          "cachePolicy": ["DEFAULT"],
          "evictionDay": [],
          "evictionHour": [],
          "evictionMinute": [],
          "maxLifespan": [],
          "batchSizeForSync": ["1000"],
          "editMode": ["READ_ONLY"],
          "importEnabled": ["true"],
          "syncRegistrations": ["false"],
          "vendor": ["other"],
          "usernameLDAPAttribute": ["uid"],
          "rdnLDAPAttribute": ["uid"],
          "uuidLDAPAttribute": ["entryUUID"],
          "userObjectClasses": ["inetOrgPerson,organizationalPerson"],
          "connectionUrl": ["ldap://openldap:389"],
          "usersDn": ["ou=users,dc=opensupervisor,dc=local"],
          "authType": ["simple"],
          "bindDn": ["cn=admin,dc=opensupervisor,dc=local"],
          "bindCredential": ["admin123"],
          "searchScope": ["2"],
          "useTruststoreSpi": ["ldapsOnly"],
          "connectionPooling": ["true"],
          "connectionPoolingAuthentication": ["true"],
          "connectionPoolingDebug": ["false"],
          "connectionPoolingInitSize": ["1"],
          "connectionPoolingMaxSize": ["5"],
          "connectionPoolingPrefSize": ["1"],
          "connectionPoolingProtocol": ["plain"],
          "connectionPoolingTimeout": ["30000"],
          "connectionTimeout": ["30000"],
          "readTimeout": ["30000"],
          "pagination": ["true"],
          "allowKerberosAuthentication": ["false"],
          "debug": ["false"],
          "useKerberosForPasswordAuthentication": ["false"]
        }
      }
    ]
  },
  "identityProviderMappers": [],
  "defaultRole": {
    "name": "default-roles-open-supervisor",
    "description": "${role_default-roles}",
    "composite": true,
    "clientRole": false
  }
}
