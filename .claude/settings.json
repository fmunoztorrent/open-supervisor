{
  "permissions": {
    "allow": [
      "Read(//.claude/**)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(pnpm --filter authorization-service test --passWithNoTests)",
      "Bash(./node_modules/.bin/jest --passWithNoTests)",
      "Bash(./node_modules/.bin/jest --showConfig)",
      "Bash(pnpm --filter authorization-service test)",
      "Bash(pnpm --filter authorization-service test --forceExit)",
      "Bash(pnpm --filter authorization-service test -- --verbose)",
      "Bash(pnpm --filter authorization-service test --coverage)",
      "Bash(pnpm --filter sse-server test)",
      "Bash(pnpm --filter sse-server test --forceExit)",
      "Bash(pnpm --filter bff test --forceExit)",
      "Bash(pnpm --filter shared-types test --forceExit)",
      "Bash(pnpm --filter authorization-service typecheck)",
      "Bash(pnpm --filter sse-server typecheck)",
      "Bash(pnpm --filter shared-types typecheck)",
      "Bash(pnpm --filter shared-messaging typecheck)",
      "Bash(tsc --noEmit)",
      "Bash(pnpm approve-builds *)",
      "Bash(pnpm lint *)",
      "Bash(npx jest *)",
      "Bash(npx @react-native-community/cli@15.1.3 init OpenSupervisor --skip-install)",
      "Bash(npx react-native init *)",
      "Bash(npx @react-native-community/cli init *)",
      "Bash(chmod +x setup-android.sh)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/pipeline/coordination.sh register claude 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/pipeline/coordination.sh release claude 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .opencode/pipeline/coordination-claude-hook.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .opencode/pipeline/pipeline-cli.mjs guard-edit"
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "node .opencode/pipeline/pipeline-cli.mjs check-activation"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "node .opencode/pipeline/pipeline-cli.mjs sync-todos; echo \"── Modelo activo: ${CLAUDE_MODEL:-desconocido} ──\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'HOOK: Tarea completada. Antes de cerrar: (1) actualiza el spec en spec/ marcando tareas completadas y agrega seccion ## Resultado; (2) agrega una entrada en .claude/LEARNINGS.md si aprendiste algo no obvio; (3) actualiza CLAUDE.md si hay cambios arquitecturales, nuevas convenciones o decisiones que deben persistir.'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .opencode/pipeline/close-pending.json ] && npx tsx scripts/extract-learnings.ts 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
