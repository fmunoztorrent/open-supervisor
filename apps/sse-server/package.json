{
  "name": "@open-supervisor/sse-server",
  "version": "0.0.1",
  "scripts": {
    "build": "rm -rf tsconfig*.tsbuildinfo && nest build",
    "dev": "rm -rf tsconfig*.tsbuildinfo && nest start --watch",
    "start": "node dist/main",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@open-supervisor/shared-messaging": "workspace:*",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/instrumentation-express": "0.67.0",
    "@opentelemetry/instrumentation-http": "0.219.0",
    "@opentelemetry/instrumentation-ioredis": "0.67.0",
    "@opentelemetry/instrumentation-nestjs-core": "0.65.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "ioredis": "^5.3.2",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.0.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.spec.json"
        }
      ]
    },
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@open-supervisor/shared-messaging": "<rootDir>/../node_modules/@open-supervisor/shared-messaging/src"
    }
  }
}
