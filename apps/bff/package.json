{
  "name": "@open-supervisor/bff",
  "version": "0.0.1",
  "scripts": {
    "build": "rm -rf tsconfig*.tsbuildinfo && nest build",
    "dev": "rm -rf tsconfig*.tsbuildinfo && nest start --watch",
    "start": "node dist/main",
    "test": "jest",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@open-supervisor/shared-types": "workspace:*",
    "eventsource": "^2.0.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/eventsource": "^1.1.15",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^6.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "testEnvironment": "node"
  }
}
