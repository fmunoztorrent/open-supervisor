    "@open-supervisor/shared-types": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "jwt-decode": "^4.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-config": "^1.5.3",
    "react-native-sse": "^1.2.0",
    "react-native-svg": "^15.15.5",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
