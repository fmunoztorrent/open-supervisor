{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "tsconfig.e2e.json"
      }
    ]
  },
  "testEnvironment": "node",
  "testTimeout": 30000,
  "globalSetup": "<rootDir>/test/setup/global-setup.ts",
  "globalTeardown": "<rootDir>/test/setup/global-teardown.ts",
  "moduleNameMapper": {
    "@open-supervisor/shared-types": "<rootDir>/node_modules/@open-supervisor/shared-types/src",
    "@open-supervisor/shared-messaging": "<rootDir>/node_modules/@open-supervisor/shared-messaging/src"
  }
}
