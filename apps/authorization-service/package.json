{
  "name": "@open-supervisor/authorization-service",
  "version": "0.0.1",
  "scripts": {
    "build": "rm -rf tsconfig*.tsbuildinfo && nest build",
    "dev": "rm -rf tsconfig*.tsbuildinfo && nest start --watch",
    "start": "node dist/main",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:test:setup": "tsx scripts/setup-test-db.ts",
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@open-supervisor/shared-messaging": "workspace:*",
    "@open-supervisor/shared-types": "workspace:*",
    "axios": "^1.16.1",
    "drizzle-orm": "^0.36.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^9.0.0",
    "drizzle-kit": "^0.28.0",
    "jest": "^29.0.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.spec.json"
        }
      ]
    },
    "coverageDirectory": "coverage",
    "coverageReporters": ["lcov", "text"],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@open-supervisor/shared-types": "<rootDir>/../node_modules/@open-supervisor/shared-types/src",
      "@open-supervisor/shared-messaging": "<rootDir>/../node_modules/@open-supervisor/shared-messaging/src"
    }
  }
}
