# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=open-supervisor

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka topics
KAFKA_TOPIC_AUTH_REQUESTS=auth.requests
# auth.response.{store_id} se construye dinámicamente por store_id

# PostgreSQL (Drizzle ORM)
DATABASE_URL=postgresql://open_supervisor:dev_password@localhost:5432/open_supervisor
DATABASE_URL_TEST=postgresql://open_supervisor:dev_password@localhost:5432/open_supervisor_test

# Outbox publisher
OUTBOX_TICK_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
