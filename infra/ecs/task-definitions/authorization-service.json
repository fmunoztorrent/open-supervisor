{
  "family": "open-supervisor-authorization-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<aws_account_id>:role/open-supervisor-<environment>-ecs-task-execution",
  "taskRoleArn": "arn:aws:iam::<aws_account_id>:role/open-supervisor-<environment>-task",
  "containerDefinitions": [
    {
      "name": "authorization-service",
      "image": "<aws_account_id>.dkr.ecr.us-east-1.amazonaws.com/open-supervisor/authorization-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp",
          "name": "auth-http"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3001/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3001"
        }
      ],
      "secrets": [
        {
          "name": "KAFKA_BROKER",
          "valueFrom": "arn:aws:ssm:<aws_region>:<aws_account_id>:parameter/open-supervisor/<environment>/KAFKA_BROKER"
        },
        {
          "name": "REDIS_HOST",
          "valueFrom": "arn:aws:ssm:<aws_region>:<aws_account_id>:parameter/open-supervisor/<environment>/REDIS_HOST"
        },
        {
          "name": "REDIS_PORT",
          "valueFrom": "arn:aws:ssm:<aws_region>:<aws_account_id>:parameter/open-supervisor/<environment>/REDIS_PORT"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:<aws_region>:<aws_account_id>:parameter/open-supervisor/<environment>/DATABASE_URL"
        },
        {
          "name": "KEYCLOAK_URL",
          "valueFrom": "arn:aws:ssm:<aws_region>:<aws_account_id>:parameter/open-supervisor/<environment>/KEYCLOAK_URL"
        },
        {
          "name": "KEYCLOAK_REALM",
          "valueFrom": "arn:aws:ssm:<aws_region>:<aws_account_id>:parameter/open-supervisor/<environment>/KEYCLOAK_REALM"
        },
        {
          "name": "KEYCLOAK_CLIENT_ID",
          "valueFrom": "arn:aws:ssm:<aws_region>:<aws_account_id>:parameter/open-supervisor/<environment>/KEYCLOAK_CLIENT_ID"
        },
        {
          "name": "KEYCLOAK_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:<aws_region>:<aws_account_id>:secret:/open-supervisor/<environment>/KEYCLOAK_CLIENT_SECRET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/authorization-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "tags": [
    {
      "key": "Name",
      "value": "open-supervisor-authorization-service-task"
    },
    {
      "key": "Environment",
      "value": "<environment>"
    },
    {
      "key": "Project",
      "value": "open-supervisor"
    }
  ]
}
